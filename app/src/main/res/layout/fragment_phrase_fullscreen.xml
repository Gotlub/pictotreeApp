<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:padding="16dp">

    <!-- Bouton Fermer (En haut à gauche ou au centre gauche en paysage) -->
    <ImageButton
        android:id="@+id/btn_close_fullscreen"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        android:scaleType="centerInside"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:contentDescription="Fermer" />

    <!-- Le RecyclerView de la phrase : il doit prendre TOUT l'espace central -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_phrase_fullscreen"
        android:layout_width="0dp"
        android:layout_height="300dp"
        android:clipToPadding="false"
        android:paddingHorizontal="16dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/btn_close_fullscreen"
        app:layout_constraintEnd_toStartOf="@id/fab_speak_fullscreen"
        tools:listitem="@layout/item_phrase_picto" />

    <!-- Bouton Lecture (En bas à droite ou au centre droit en paysage) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_speak_fullscreen"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@android:drawable/ic_btn_speak_now"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:contentDescription="Lire la phrase" />

</androidx.constraintlayout.widget.ConstraintLayout>
