<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:padding="16dp">

    <!-- Bouton Fermer -->
    <ImageButton
        android:id="@+id/btn_close_fullscreen"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_margin="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        android:scaleType="centerInside"
        android:elevation="35dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:contentDescription="Fermer" />

    <!-- Le RecyclerView central (HAUTEUR FIXE POUR LAISSER DU CIEL AU SWIPE) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_phrase_fullscreen"
        android:layout_width="match_parent"
        android:layout_height="320dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:paddingHorizontal="120dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:listitem="@layout/item_phrase_picto" />

    <!-- BLOC CONTRÔLES BAS GAUCHE (Segmented Bar) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/panel_size_control"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/rounded_bottom_sheet"
        android:backgroundTint="#F5F5F5"
        android:padding="8dp"
        android:elevation="35dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/tv_size_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SIZE"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#666666"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginStart="4dp" />

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggle_phrase_size"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            app:singleSelection="true"
            app:selectionRequired="true"
            app:checkedButton="@+id/btn_size_m"
            app:layout_constraintTop_toBottomOf="@id/tv_size_label"
            app:layout_constraintStart_toStartOf="parent">
            
            <com.google.android.material.button.MaterialButton 
                android:id="@+id/btn_size_s" 
                style="?attr/materialButtonOutlinedStyle" 
                android:layout_width="54dp" 
                android:layout_height="44dp" 
                android:text="S" 
                android:textSize="14sp"
                android:padding="0dp"
                app:strokeColor="#DDDDDD" />
                
            <com.google.android.material.button.MaterialButton 
                android:id="@+id/btn_size_m" 
                style="?attr/materialButtonOutlinedStyle" 
                android:layout_width="54dp" 
                android:layout_height="44dp" 
                android:text="M" 
                android:textSize="18sp"
                android:padding="0dp"
                app:strokeColor="#DDDDDD" />
                
            <com.google.android.material.button.MaterialButton 
                android:id="@+id/btn_size_l" 
                style="?attr/materialButtonOutlinedStyle" 
                android:layout_width="54dp" 
                android:layout_height="44dp" 
                android:text="L" 
                android:textSize="22sp"
                android:padding="0dp"
                app:strokeColor="#DDDDDD" />
                
        </com.google.android.material.button.MaterialButtonToggleGroup>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Bouton Lecture -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_speak_fullscreen"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        android:src="@android:drawable/ic_btn_speak_now"
        app:elevation="35dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:contentDescription="Lire la phrase" />

</androidx.constraintlayout.widget.ConstraintLayout>
