<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- Bouton Fermer (Désormais calé dans le coin haut gauche) -->
    <ImageButton
        android:id="@+id/btn_close_fullscreen"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_margin="12dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        android:scaleType="centerInside"
        android:elevation="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:contentDescription="Fermer" />

    <!-- Le RecyclerView central -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_phrase_fullscreen"
        android:layout_width="match_parent"
        android:layout_height="320dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:paddingHorizontal="120dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:listitem="@layout/item_phrase_picto" />

    <!-- SÉLECTEUR DE TAILLE MINIMALISTE (Calé en bas à gauche) -->
    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/toggle_phrase_size"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:singleSelection="true"
        app:selectionRequired="true"
        app:checkedButton="@+id/btn_size_m"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent">
        
        <com.google.android.material.button.MaterialButton 
            android:id="@+id/btn_size_s" 
            style="?attr/materialButtonOutlinedStyle" 
            android:layout_width="44dp" 
            android:layout_height="44dp" 
            app:icon="@android:drawable/presence_invisible" 
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="12dp"
            app:iconTint="#999999"
            android:padding="0dp"
            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.Material3.Button.Circle"
            app:strokeColor="#EEEEEE" />
            
        <com.google.android.material.button.MaterialButton 
            android:id="@+id/btn_size_m" 
            style="?attr/materialButtonOutlinedStyle" 
            android:layout_width="44dp" 
            android:layout_height="44dp" 
            app:icon="@android:drawable/presence_invisible" 
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="20dp"
            app:iconTint="#666666"
            android:padding="0dp"
            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.Material3.Button.Circle"
            app:strokeColor="#EEEEEE" />
            
        <com.google.android.material.button.MaterialButton 
            android:id="@+id/btn_size_l" 
            style="?attr/materialButtonOutlinedStyle" 
            android:layout_width="44dp" 
            android:layout_height="44dp" 
            app:icon="@android:drawable/presence_invisible" 
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="28dp"
            app:iconTint="#333333"
            android:padding="0dp"
            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.Material3.Button.Circle"
            app:strokeColor="#EEEEEE" />
            
    </com.google.android.material.button.MaterialButtonToggleGroup>

    <!-- Bouton Lecture (Calé en bas à droite) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_speak_fullscreen"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        android:src="@android:drawable/ic_btn_speak_now"
        app:backgroundTint="@color/primary_color"
        app:tint="@color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:contentDescription="Lire la phrase" />

</androidx.constraintlayout.widget.ConstraintLayout>
