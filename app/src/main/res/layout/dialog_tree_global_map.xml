<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <!-- WebView for Treant.js -->
    <WebView
        android:id="@+id/web_view_map"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/panel_phrase"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- TOP BAR ACTIONS (Synchronisées avec fragment_tree_explorer) -->
    <LinearLayout
        android:id="@+id/container_actions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Bouton Retour (Ferme le dialogue et revient à l'endroit exact dans l'explorateur) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btn_back_to_nav"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="#EDE7F6"
            app:cardElevation="2dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="10dp"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="#5E35B1" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Bouton Recherche -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_search"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="#EDE7F6"
            app:cardElevation="2dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="10dp"
                android:src="@android:drawable/ic_menu_search"
                app:tint="#5E35B1" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Bouton Grille (Retour aux arbres) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_back_to_trees"
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="#EDE7F6"
            app:cardElevation="2dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="10dp"
                android:src="@android:drawable/ic_dialog_dialer"
                app:tint="#5E35B1" />
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <!-- Preview and Add Panel -->
    <LinearLayout
        android:id="@+id/panel_selection_preview"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toTopOf="@id/panel_phrase"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:id="@+id/iv_selection_preview"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="@drawable/rounded_bottom_sheet"
            android:backgroundTint="#F0F0F0"
            android:padding="4dp"
            android:scaleType="centerInside"
            android:visibility="gone"
            tools:visibility="visible"
            tools:src="@drawable/ic_launcher_foreground" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_add_to_basket"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Ajouter"
            android:textAllCaps="false"
            app:cornerRadius="20dp" />
    </LinearLayout>

    <!-- NAVIGATION ARROWS -->
    <ImageButton
        android:id="@+id/btn_prev_tree"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginStart="8dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="Arbre précédent"
        android:src="@android:drawable/ic_media_previous"
        app:tint="#6200EE"
        android:elevation="4dp"
        app:layout_constraintBottom_toBottomOf="@id/web_view_map"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/web_view_map" />

    <ImageButton
        android:id="@+id/btn_next_tree"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginEnd="8dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="Arbre suivant"
        android:src="@android:drawable/ic_media_next"
        app:tint="#6200EE"
        android:elevation="4dp"
        app:layout_constraintBottom_toBottomOf="@id/web_view_map"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/web_view_map" />

    <!-- BANDEAU DE PHRASE (Panier) - ABSOLUTE BOTTOM -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/panel_phrase"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:background="@drawable/rounded_bottom_sheet"
        android:elevation="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Ghost Frames for empty state -->
        <LinearLayout
            android:id="@+id/layout_ghost_frames"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <View android:layout_width="110dp" android:layout_height="match_parent" android:layout_marginEnd="8dp" android:background="@drawable/bg_ghost_frame" />
            <View android:layout_width="110dp" android:layout_height="match_parent" android:layout_marginEnd="8dp" android:background="@drawable/bg_ghost_frame" />
            <View android:layout_width="110dp" android:layout_height="match_parent" android:layout_marginEnd="8dp" android:background="@drawable/bg_ghost_frame" />
            <View android:layout_width="110dp" android:layout_height="match_parent" android:layout_marginEnd="8dp" android:background="@drawable/bg_ghost_frame" />
            <View android:layout_width="110dp" android:layout_height="match_parent" android:layout_marginEnd="8dp" android:background="@drawable/bg_ghost_frame" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btn_fullscreen_phrase"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_margin="4dp"
            android:padding="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_zoom"
            android:elevation="20dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:contentDescription="Mode plein écran" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_phrase"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:clipToPadding="false"
            android:paddingHorizontal="16dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:listitem="@layout/item_phrase_picto" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_speak_dialog"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
        android:src="@android:drawable/ic_btn_speak_now"
        app:layout_constraintBottom_toTopOf="@id/panel_phrase"
        app:layout_constraintEnd_toEndOf="parent"
        android:contentDescription="Lire la phrase" />

</androidx.constraintlayout.widget.ConstraintLayout>
