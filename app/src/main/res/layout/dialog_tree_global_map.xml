<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <!-- WebView for Treant.js -->
    <WebView
        android:id="@+id/web_view_map"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/layout_bottom_actions"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Left Arrow (Previous Tree) -->
    <ImageButton
        android:id="@+id/btn_prev_tree"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginStart="16dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="Arbre précédent"
        android:src="@android:drawable/ic_media_previous"
        android:backgroundTint="#80FFFFFF"
        android:elevation="4dp"
        app:layout_constraintBottom_toBottomOf="@id/web_view_map"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/web_view_map" />

    <!-- Right Arrow (Next Tree) -->
    <ImageButton
        android:id="@+id/btn_next_tree"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginEnd="16dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="Arbre suivant"
        android:src="@android:drawable/ic_media_next"
        android:backgroundTint="#80FFFFFF"
        android:elevation="4dp"
        app:layout_constraintBottom_toBottomOf="@id/web_view_map"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/web_view_map" />

    <!-- Bottom Actions Container -->
    <LinearLayout
        android:id="@+id/layout_bottom_actions"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Add to Basket Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_add_to_basket"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:text="Ajouter au Panier" />

        <!-- Back to View 4 Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_back_to_nav"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="Retour Navigation" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
