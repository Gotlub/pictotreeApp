<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false"
        android:paddingBottom="180dp">

        <!-- GUIDELINES POUR PARTAGE ÉQUITABLE DE L'ESPACE (3 zones) -->
        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/gl_top_zone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.33" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/gl_middle_zone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.66" />

        <!-- 1. ZONE HAUTE (Parent) -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/top_bar"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:clipChildren="false"
            app:layout_constraintStart_toEndOf="@id/container_breadcrumbs"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/gl_top_zone">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/container_parent"
                android:layout_width="140dp"
                android:layout_height="180dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:strokeWidth="2dp"
                app:strokeColor="@color/material_dynamic_neutral90"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/container_actions"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">
                
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="8dp">
                    <ImageView
                        android:id="@+id/iv_parent"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:scaleType="centerInside"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toTopOf="@id/tv_parent_label"
                        tools:src="@drawable/ic_launcher_background" />
                    <TextView
                        android:id="@+id/tv_parent_label"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:ellipsize="end"
                        app:layout_constraintBottom_toBottomOf="parent"
                        tools:text="Parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Flèche Parent -> Frères -->
            <ImageView
                android:id="@+id/iv_arrow_to_siblings"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/arrow_down_float"
                app:tint="#CCCCCC"
                android:elevation="12dp"
                app:layout_constraintTop_toBottomOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="@id/container_parent"
                app:layout_constraintEnd_toEndOf="@id/container_parent" />

            <!-- Actions (VERTICALES) -->
            <LinearLayout
                android:id="@+id/container_actions"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center_vertical|end"
                android:layout_marginEnd="16dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_eye"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="#EDE7F6"
                    app:cardElevation="2dp"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView
                        android:id="@+id/iv_eye"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="10dp"
                        android:src="@android:drawable/ic_menu_view"
                        app:tint="#5E35B1" />
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_search"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="#EDE7F6"
                    app:cardElevation="2dp"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView
                        android:id="@+id/iv_search"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="10dp"
                        android:src="@android:drawable/ic_menu_search"
                        app:tint="#5E35B1" />
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_back_to_trees"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="#EDE7F6"
                    app:cardElevation="2dp"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView
                        android:id="@+id/iv_grid"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="10dp"
                        android:src="@android:drawable/ic_dialog_dialer"
                        app:tint="#5E35B1" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- 2. ZONE MILIEU (Frères) -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/middle_container"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintTop_toBottomOf="@id/gl_top_zone"
            app:layout_constraintBottom_toTopOf="@id/gl_middle_zone">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_siblings"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:clipToPadding="false"
                android:paddingHorizontal="40dp"
                android:orientation="horizontal"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                tools:listitem="@layout/item_sibling_node" />

            <!-- Indicateurs de scroll Frères (Gradients + Flèches) -->
            <View
                android:id="@+id/siblings_gradient_left"
                android:layout_width="60dp"
                android:layout_height="match_parent"
                android:background="@drawable/scroll_gradient_left"
                android:visibility="invisible"
                app:layout_constraintStart_toStartOf="parent" />
            <ImageView
                android:id="@+id/iv_siblings_arrow_left"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_media_previous"
                android:alpha="0.5"
                android:visibility="invisible"
                android:layout_marginStart="8dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <View
                android:id="@+id/siblings_gradient_right"
                android:layout_width="60dp"
                android:layout_height="match_parent"
                android:background="@drawable/scroll_gradient_right"
                android:visibility="invisible"
                app:layout_constraintEnd_toEndOf="parent" />
            <ImageView
                android:id="@+id/iv_siblings_arrow_right"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_media_next"
                android:alpha="0.5"
                android:visibility="invisible"
                android:layout_marginEnd="8dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- 3. ZONE BASSE (Enfants) -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/bottom_nav_zone"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintTop_toBottomOf="@id/gl_middle_zone"
            app:layout_constraintBottom_toBottomOf="parent">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_children_preview"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:clipToPadding="false"
                android:paddingStart="120dp"
                android:paddingEnd="16dp"
                android:orientation="horizontal"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                tools:listitem="@layout/item_sibling_node" />

            <!-- Indicateurs de scroll Enfants (Gradients + Flèches) -->
            <View
                android:id="@+id/children_gradient_left"
                android:layout_width="60dp"
                android:layout_height="match_parent"
                android:background="@drawable/scroll_gradient_left"
                android:visibility="invisible"
                app:layout_constraintStart_toStartOf="parent" />
            <ImageView
                android:id="@+id/iv_children_arrow_left"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_media_previous"
                android:alpha="0.5"
                android:visibility="invisible"
                android:layout_marginStart="8dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <View
                android:id="@+id/children_gradient_right"
                android:layout_width="60dp"
                android:layout_height="match_parent"
                android:background="@drawable/scroll_gradient_right"
                android:visibility="invisible"
                app:layout_constraintEnd_toEndOf="parent" />
            <ImageView
                android:id="@+id/iv_children_arrow_right"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_media_next"
                android:alpha="0.5"
                android:visibility="invisible"
                android:layout_marginEnd="8dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- FLÈCHE FLOTTANTE MILIEU (Dynamique) -->
        <ImageView
            android:id="@+id/iv_arrow_to_children"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/arrow_down_float"
            android:visibility="invisible"
            app:tint="#CCCCCC"
            android:elevation="12dp"
            app:layout_constraintTop_toBottomOf="@id/gl_middle_zone"
            app:layout_constraintBottom_toTopOf="@id/gl_middle_zone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- CALQUES DE PREMIER PLAN (Fixes) -->

        <!-- Breadcrumb (Fil d'Ariane) -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/container_breadcrumbs"
            android:layout_width="66dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:elevation="8dp"
            app:layout_constrainedHeight="true"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/layout_action"
            app:layout_constraintVertical_bias="0.0">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_breadcrumbs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:scrollbars="none"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                tools:listitem="@layout/item_breadcrumb" />

            <View
                android:id="@+id/breadcrumb_scroll_top"
                android:layout_width="match_parent"
                android:layout_height="20dp"
                android:background="@drawable/scroll_gradient_top"
                android:visibility="invisible"
                app:layout_constraintTop_toTopOf="parent" />

            <View
                android:id="@+id/breadcrumb_scroll_bottom"
                android:layout_width="match_parent"
                android:layout_height="20dp"
                android:background="@drawable/scroll_gradient_bottom"
                android:visibility="invisible"
                app:layout_constraintBottom_toBottomOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Zone Action (Miniature + Ajouter) -->
        <LinearLayout
            android:id="@+id/layout_action"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginStart="8dp"
            android:layout_marginBottom="16dp"
            android:elevation="10dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:id="@+id/iv_selected_large"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@drawable/rounded_bottom_sheet"
                android:backgroundTint="#F0F0F0"
                android:padding="4dp"
                android:scaleType="centerInside"
                tools:src="@drawable/ic_launcher_background" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_add_to_phrase"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Ajouter"
                android:textAllCaps="false"
                app:cornerRadius="20dp" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- BANDEAU DE PHRASE FIXE (Panier) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/panel_phrase"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:layout_gravity="bottom"
        android:background="@drawable/rounded_bottom_sheet"
        android:elevation="16dp">

        <ImageButton
            android:id="@+id/btn_fullscreen_phrase"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_margin="4dp"
            android:padding="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_zoom"
            android:elevation="20dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_phrase"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:clipToPadding="false"
            android:paddingHorizontal="16dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:listitem="@layout/item_phrase_picto" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_speak"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="188dp"
        android:src="@android:drawable/ic_btn_speak_now"
        app:elevation="12dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
