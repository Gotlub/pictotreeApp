<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false"
        android:paddingBottom="180dp">

        <androidx.constraintlayout.widget.Guideline android:id="@+id/gl_top_zone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" app:layout_constraintGuide_percent="0.33" />
        <androidx.constraintlayout.widget.Guideline android:id="@+id/gl_middle_zone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" app:layout_constraintGuide_percent="0.66" />

        <!-- 1. NAVIGATION LAYERS (Arrière-plan) -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_siblings"
            android:layout_width="0dp"
            android:layout_height="180dp"
            android:clipToPadding="false"
            android:paddingStart="160dp" 
            android:paddingEnd="120dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/gl_top_zone"
            app:layout_constraintBottom_toTopOf="@id/gl_middle_zone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:listitem="@layout/item_sibling_node" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/bottom_nav_zone"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintTop_toBottomOf="@id/gl_middle_zone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
            <androidx.recyclerview.widget.RecyclerView android:id="@+id/rv_children_preview" android:layout_width="match_parent" android:layout_height="180dp" android:clipToPadding="false" android:paddingStart="16dp" android:paddingEnd="160dp" android:orientation="horizontal" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent" tools:listitem="@layout/item_sibling_node" />
            <View android:id="@+id/children_gradient_left" android:layout_width="60dp" android:layout_height="match_parent" android:background="@drawable/scroll_gradient_left" android:visibility="invisible" app:layout_constraintStart_toStartOf="parent" />
            <View android:id="@+id/children_gradient_right" android:layout_width="60dp" android:layout_height="match_parent" android:background="@drawable/scroll_gradient_right" android:visibility="invisible" app:layout_constraintEnd_toEndOf="parent" />
            <ImageView android:id="@+id/iv_children_arrow_left" android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_media_previous" android:alpha="0.5" android:visibility="invisible" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent" />
            <ImageView android:id="@+id/iv_children_arrow_right" android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_media_next" android:alpha="0.5" android:visibility="invisible" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- 2. PANNEAUX FIXES (Milieu) -->
        
        <!-- Parent Card (GAUCHE) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/container_parent"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"
            android:elevation="10dp"
            app:cardCornerRadius="16dp"
            app:strokeWidth="3dp"
            app:strokeColor="@color/material_dynamic_neutral90"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="match_parent" android:layout_height="match_parent" android:padding="8dp">
                <ImageView android:id="@+id/iv_parent" android:layout_width="match_parent" android:layout_height="0dp" android:scaleType="centerInside" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toTopOf="@id/tv_parent_label" />
                <TextView android:id="@+id/tv_parent_label" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:textSize="12sp" android:textStyle="bold" android:maxLines="1" app:layout_constraintBottom_toBottomOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Fil d'Ariane VERTICAL (À droite du parent) -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/container_breadcrumbs"
            android:layout_width="66dp"
            android:layout_height="140dp"
            android:layout_marginTop="8dp"
            android:layout_marginStart="4dp"
            android:elevation="10dp"
            app:layout_constraintStart_toEndOf="@id/container_parent"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_breadcrumbs"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:clipToPadding="false"
                tools:listitem="@layout/item_breadcrumb" />

            <!-- Indicateurs de scroll Verticaux -->
            <View android:id="@+id/breadcrumb_scroll_top" android:layout_width="match_parent" android:layout_height="30dp" android:background="@drawable/scroll_gradient_top" android:visibility="invisible" app:layout_constraintTop_toTopOf="parent" />
            <View android:id="@+id/breadcrumb_scroll_bottom" android:layout_width="match_parent" android:layout_height="30dp" android:background="@drawable/scroll_gradient_bottom" android:visibility="invisible" app:layout_constraintBottom_toBottomOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Bloc Actions (DROITE) -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/container_actions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:layout_marginEnd="16dp"
            android:elevation="10dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <com.google.android.material.card.MaterialCardView android:id="@+id/card_search" android:layout_width="48dp" android:layout_height="48dp" app:cardCornerRadius="12dp" app:cardBackgroundColor="#EDE7F6" app:cardElevation="2dp"><ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:padding="10dp" android:src="@android:drawable/ic_menu_search" app:tint="#5E35B1" /></com.google.android.material.card.MaterialCardView>
            <com.google.android.material.card.MaterialCardView android:id="@+id/card_speak" android:layout_width="48dp" android:layout_height="48dp" app:cardCornerRadius="12dp" app:cardBackgroundColor="#E8F5E9" app:cardElevation="2dp"><ImageView android:id="@+id/iv_speak_icon" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="10dp" android:src="@android:drawable/ic_btn_speak_now" app:tint="#2E7D32" /></com.google.android.material.card.MaterialCardView>
            <com.google.android.material.card.MaterialCardView android:id="@+id/card_eye" android:layout_width="48dp" android:layout_height="48dp" app:cardCornerRadius="12dp" app:cardBackgroundColor="#EDE7F6" app:cardElevation="2dp"><ImageView android:id="@+id/iv_eye" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="10dp" android:src="@drawable/ic_tree_structure" app:tint="#5E35B1" /></com.google.android.material.card.MaterialCardView>
            <com.google.android.material.card.MaterialCardView android:id="@+id/card_back_to_trees" android:layout_width="48dp" android:layout_height="48dp" app:cardCornerRadius="12dp" app:cardBackgroundColor="#EDE7F6" app:cardElevation="2dp"><ImageView android:id="@+id/iv_grid" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="10dp" android:src="@android:drawable/ic_dialog_dialer" app:tint="#5E35B1" /></com.google.android.material.card.MaterialCardView>
            <androidx.constraintlayout.helper.widget.Flow android:id="@+id/flow_actions" android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" app:flow_verticalGap="8dp" app:constraint_referenced_ids="card_search,card_speak,card_eye,card_back_to_trees" app:layout_constraintTop_toTopOf="parent" app:layout_constraintEnd_toEndOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <LinearLayout android:id="@+id/layout_action" android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center" android:layout_marginEnd="16dp" android:layout_marginBottom="16dp" android:elevation="10dp" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintBottom_toBottomOf="parent">
            <ImageView android:id="@+id/iv_selected_large" android:layout_width="80dp" android:layout_height="80dp" android:background="@drawable/rounded_bottom_sheet" android:backgroundTint="#F0F0F0" android:padding="4dp" android:scaleType="centerInside" />
            <com.google.android.material.button.MaterialButton android:id="@+id/btn_add_to_phrase" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Ajouter" android:textAllCaps="false" app:cornerRadius="20dp" />
        </LinearLayout>

        <!-- 3. TOP LAYERS (Arrows) -->
        <ImageView android:id="@+id/iv_arrow_to_siblings" android:layout_width="32dp" android:layout_height="32dp" android:src="@android:drawable/arrow_down_float" app:tint="@color/primary_color" android:elevation="15dp" app:layout_constraintTop_toBottomOf="@id/container_parent" app:layout_constraintBottom_toTopOf="@id/rv_siblings" app:layout_constraintStart_toStartOf="@id/container_parent" app:layout_constraintEnd_toEndOf="@id/container_parent" />
        <ImageView android:id="@+id/iv_arrow_to_children" android:layout_width="32dp" android:layout_height="32dp" android:src="@android:drawable/arrow_down_float" android:visibility="invisible" app:tint="@color/primary_color" android:elevation="15dp" app:layout_constraintTop_toBottomOf="@id/gl_middle_zone" app:layout_constraintBottom_toTopOf="@id/gl_middle_zone" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent" />

        <!-- Indicateurs scroll SIBLINGS -->
        <View android:id="@+id/siblings_gradient_left" android:layout_width="60dp" android:layout_height="0dp" android:background="@drawable/scroll_gradient_left" android:visibility="invisible" android:elevation="16dp" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/gl_top_zone" app:layout_constraintBottom_toTopOf="@id/gl_middle_zone" />
        <View android:id="@+id/siblings_gradient_right" android:layout_width="60dp" android:layout_height="0dp" android:background="@drawable/scroll_gradient_right" android:visibility="invisible" android:elevation="16dp" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toBottomOf="@id/gl_top_zone" app:layout_constraintBottom_toTopOf="@id/gl_middle_zone" />
        <ImageView android:id="@+id/iv_siblings_arrow_left" android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_media_previous" android:alpha="0.5" android:visibility="invisible" android:elevation="17dp" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/gl_top_zone" app:layout_constraintBottom_toTopOf="@id/gl_middle_zone" />
        <ImageView android:id="@+id/iv_siblings_arrow_right" android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_media_next" android:alpha="0.5" android:visibility="invisible" android:elevation="17dp" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toBottomOf="@id/gl_top_zone" app:layout_constraintBottom_toTopOf="@id/gl_middle_zone" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/panel_phrase"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:layout_gravity="bottom"
        android:background="@drawable/rounded_bottom_sheet"
        android:elevation="20dp">
        <ImageButton android:id="@+id/btn_fullscreen_phrase" android:layout_width="48dp" android:layout_height="48dp" android:layout_margin="4dp" android:background="?attr/selectableItemBackgroundBorderless" android:src="@android:drawable/ic_menu_zoom" app:layout_constraintTop_toTopOf="parent" app:layout_constraintEnd_toEndOf="parent" />
        <androidx.recyclerview.widget.RecyclerView android:id="@+id/rv_phrase" android:layout_width="0dp" android:layout_height="0dp" android:layout_marginTop="8dp" android:layout_marginBottom="8dp" android:clipToPadding="false" android:paddingHorizontal="16dp" android:orientation="horizontal" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent" tools:listitem="@layout/item_phrase_picto" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <View android:id="@+id/fab_speak" android:layout_width="1dp" android:layout_height="1dp" android:visibility="gone" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
