<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="180dp">

        <!-- 1. TOP BAR -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/top_bar"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Breadcrumb (Parents lointains) - A GAUCHE, VERTICAL -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_breadcrumbs"
                android:layout_width="60dp"
                android:layout_height="match_parent"
                android:layout_marginStart="8dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:layout_marginEnd="8dp"
                android:orientation="vertical"
                android:scrollbars="none"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                tools:listitem="@layout/item_breadcrumb" />

            <!-- Parent Direct (CENTRE) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/container_parent"
                android:layout_width="120dp"
                android:layout_height="match_parent"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:layout_constraintStart_toEndOf="@id/rv_breadcrumbs"
                app:layout_constraintEnd_toStartOf="@id/container_actions"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">
                
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <ImageView
                        android:id="@+id/iv_parent"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:padding="8dp"
                        android:scaleType="centerInside"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toTopOf="@id/tv_parent_label"
                        tools:src="@drawable/ic_launcher_background" />
                    <TextView
                        android:id="@+id/tv_parent_label"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:gravity="center"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:maxLines="1"
                        app:layout_constraintBottom_toBottomOf="parent"
                        tools:text="Parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Actions (VERTICALES) - A DROITE -->
            <LinearLayout
                android:id="@+id/container_actions"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center_vertical|end"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <!-- Bouton Vue Treant -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_eye"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="#EDE7F6"
                    app:cardElevation="2dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">
                    <ImageView
                        android:id="@+id/iv_eye"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="10dp"
                        android:src="@android:drawable/ic_menu_view"
                        app:tint="#5E35B1" />
                </com.google.android.material.card.MaterialCardView>

                <!-- Bouton Recherche -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_search"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="#EDE7F6"
                    app:cardElevation="2dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">
                    <ImageView
                        android:id="@+id/iv_search"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="10dp"
                        android:src="@android:drawable/ic_menu_search"
                        app:tint="#5E35B1" />
                </com.google.android.material.card.MaterialCardView>

                <!-- Bouton Grille (Retour aux arbres) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_back_to_trees"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="#EDE7F6"
                    app:cardElevation="2dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">
                    <ImageView
                        android:id="@+id/iv_grid"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="10dp"
                        android:src="@android:drawable/ic_dialog_dialer"
                        app:tint="#5E35B1" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- 2. MIDDLE ZONE (Les Frères) -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_siblings"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginTop="16dp"
            android:clipToPadding="false"
            android:paddingHorizontal="40dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/top_bar"
            tools:listitem="@layout/item_phrase_picto" />

        <!-- 3. BOTTOM ZONE (Action & Preview) -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/bottom_nav_zone"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/rv_siblings"
            app:layout_constraintBottom_toBottomOf="parent">

            <!-- Guideline 40% -->
            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/guideline_split"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_percent="0.4" />

            <!-- Gauche: Action (Miniature + Ajouter) -->
            <LinearLayout
                android:id="@+id/layout_action"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginStart="16dp"
                android:layout_marginBottom="8dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/guideline_split">

                <ImageView
                    android:id="@+id/iv_selected_large"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:background="@drawable/rounded_bottom_sheet"
                    android:backgroundTint="#F0F0F0"
                    android:padding="4dp"
                    android:scaleType="centerInside"
                    tools:src="@drawable/ic_launcher_background" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_add_to_phrase"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Ajouter"
                    android:textAllCaps="false"
                    app:cornerRadius="20dp" />

            </LinearLayout>

            <!-- Droite: Preview (Enfants) -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_children_preview"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/rounded_bottom_sheet"
                android:padding="4dp"
                app:layout_constraintStart_toEndOf="@id/guideline_split"
                app:layout_constraintEnd_toEndOf="parent"
                app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                app:spanCount="3"
                tools:listitem="@layout/item_phrase_picto" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- BANDEAU DE PHRASE FIXE (Panier) - ABSOLUTE BOTTOM -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/panel_phrase"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:layout_gravity="bottom"
        android:background="@drawable/rounded_bottom_sheet"
        android:elevation="16dp">

        <ImageButton
            android:id="@+id/btn_fullscreen_phrase"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_margin="4dp"
            android:padding="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_zoom"
            android:elevation="20dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:contentDescription="Mode plein écran" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_phrase"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:clipToPadding="false"
            android:paddingHorizontal="16dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:listitem="@layout/item_phrase_picto" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_speak"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="188dp"
        android:src="@android:drawable/ic_btn_speak_now"
        app:elevation="12dp"
        android:contentDescription="Lire la phrase" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
