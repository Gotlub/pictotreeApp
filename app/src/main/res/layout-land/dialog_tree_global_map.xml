<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <!-- WebView (Fond HTML) -->
    <WebView
        android:id="@+id/web_view_map"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- BLOC ACTIONS FLOTTANT (Marge de sécurité 100dp pour les boutons système) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/container_actions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="100dp" 
        android:elevation="15dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.card.MaterialCardView android:id="@+id/card_search" android:layout_width="40dp" android:layout_height="40dp" app:cardCornerRadius="10dp" app:cardBackgroundColor="#EDE7F6" app:cardElevation="2dp"><ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:padding="10dp" android:src="@android:drawable/ic_menu_search" app:tint="#5E35B1" /></com.google.android.material.card.MaterialCardView>
        <com.google.android.material.card.MaterialCardView android:id="@+id/card_speak" android:layout_width="40dp" android:layout_height="40dp" app:cardCornerRadius="10dp" app:cardBackgroundColor="#E8F5E9" app:cardElevation="2dp"><ImageView android:id="@+id/iv_speak_icon" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="10dp" android:src="@android:drawable/ic_btn_speak_now" app:tint="#2E7D32" /></com.google.android.material.card.MaterialCardView>
        <com.google.android.material.card.MaterialCardView android:id="@+id/card_rotate" android:layout_width="40dp" android:layout_height="40dp" app:cardCornerRadius="10dp" app:cardBackgroundColor="#FFF3E0" app:cardElevation="2dp"><ImageView android:id="@+id/iv_menu_rotate" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="10dp" android:src="@android:drawable/ic_menu_rotate" app:tint="#E65100" /></com.google.android.material.card.MaterialCardView>
        <com.google.android.material.card.MaterialCardView android:id="@+id/card_back_to_trees" android:layout_width="40dp" android:layout_height="40dp" app:cardCornerRadius="10dp" app:cardBackgroundColor="#EDE7F6" app:cardElevation="2dp"><ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:padding="10dp" android:src="@android:drawable/ic_dialog_dialer" app:tint="#5E35B1" /></com.google.android.material.card.MaterialCardView>
        <com.google.android.material.card.MaterialCardView android:id="@+id/btn_back_to_nav" android:layout_width="40dp" android:layout_height="40dp" app:cardCornerRadius="10dp" app:cardBackgroundColor="#EDE7F6" app:cardElevation="2dp"><ImageView android:id="@+id/iv_eye_nav" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="10dp" android:src="@android:drawable/ic_menu_sort_by_size" app:tint="#5E35B1" /></com.google.android.material.card.MaterialCardView>

        <androidx.constraintlayout.helper.widget.Flow
            android:id="@+id/flow_treant_land"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:flow_wrapMode="aligned"
            app:flow_maxElementsWrap="3"
            app:flow_horizontalGap="8dp"
            app:flow_verticalGap="8dp"
            app:constraint_referenced_ids="card_search,card_speak,card_rotate,card_back_to_trees,btn_back_to_nav"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Preview and Add Panel (Bas Droite - Marge de sécurité 100dp) -->
    <LinearLayout
        android:id="@+id/panel_selection_preview"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginEnd="100dp" 
        android:layout_marginBottom="4dp"
        android:elevation="15dp"
        app:layout_constraintBottom_toTopOf="@id/panel_phrase"
        app:layout_constraintEnd_toEndOf="parent">
        <ImageView android:id="@+id/iv_selection_preview" android:layout_width="50dp" android:layout_height="50dp" android:background="@drawable/rounded_bottom_sheet" android:backgroundTint="#FFFFFF" android:padding="4dp" android:scaleType="centerInside" android:visibility="gone" tools:visibility="visible" tools:src="@drawable/ic_launcher_foreground" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btn_add_to_basket" android:layout_width="wrap_content" android:layout_height="32dp" android:layout_marginTop="2dp" android:text="Ajouter" android:textSize="9sp" android:textAllCaps="false" app:cornerRadius="16dp" />
    </LinearLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/panel_phrase"
        android:layout_width="match_parent"
        android:layout_height="110dp"
        android:background="@drawable/rounded_bottom_sheet"
        android:elevation="20dp"
        app:layout_constraintBottom_toBottomOf="parent">
        
        <!-- RecyclerView en premier -->
        <androidx.recyclerview.widget.RecyclerView 
            android:id="@+id/rv_phrase" 
            android:layout_width="0dp" 
            android:layout_height="match_parent" 
            android:layout_marginTop="4dp" 
            android:layout_marginBottom="4dp" 
            android:clipToPadding="false" 
            android:paddingHorizontal="24dp" 
            android:orientation="horizontal" 
            app:layout_constraintTop_toTopOf="parent" 
            app:layout_constraintBottom_toBottomOf="parent" 
            app:layout_constraintStart_toStartOf="parent" 
            app:layout_constraintEnd_toStartOf="@id/btn_fullscreen_phrase" 
            tools:listitem="@layout/item_phrase_picto" />

        <!-- Boutons en dernier avec haute elevation -->
        <ImageButton 
            android:id="@+id/btn_fullscreen_phrase" 
            android:layout_width="40dp" 
            android:layout_height="40dp"
            android:layout_marginTop="4dp"
            android:layout_marginStart="4dp"
            android:layout_marginBottom="4dp"
            android:layout_marginEnd="40dp"
            android:padding="8dp" 
            android:background="?attr/selectableItemBackgroundBorderless" 
            android:src="@android:drawable/ic_menu_zoom" 
            android:elevation="25dp" 
            app:layout_constraintTop_toTopOf="parent" 
            app:layout_constraintEnd_toEndOf="parent" />
        
        <ImageButton 
            android:id="@+id/btn_clear_phrase" 
            android:layout_width="40dp" 
            android:layout_height="40dp"
            android:layout_marginTop="4dp"
            android:layout_marginStart="4dp"
            android:layout_marginBottom="4dp"
            android:layout_marginEnd="40dp"
            android:padding="8dp" 
            android:background="?attr/selectableItemBackgroundBorderless" 
            android:src="@android:drawable/ic_menu_delete" 
            android:elevation="25dp" 
            app:layout_constraintTop_toBottomOf="@id/btn_fullscreen_phrase" 
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- NAVIGATION ARROWS (Marge de sécurité 100dp) -->
    <ImageButton android:id="@+id/btn_prev_tree" android:layout_width="56dp" android:layout_height="56dp" android:layout_marginStart="8dp" android:background="?android:attr/selectableItemBackgroundBorderless" android:src="@android:drawable/ic_media_previous" app:tint="#6200EE" android:elevation="22dp" app:layout_constraintBottom_toTopOf="@id/panel_phrase" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" />
    <ImageButton android:id="@+id/btn_next_tree" android:layout_width="56dp" android:layout_height="56dp" android:layout_marginEnd="100dp" android:background="?android:attr/selectableItemBackgroundBorderless" android:src="@android:drawable/ic_media_next" app:tint="#6200EE" android:elevation="22dp" app:layout_constraintBottom_toTopOf="@id/panel_phrase" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
