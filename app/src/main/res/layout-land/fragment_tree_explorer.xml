<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false"
        android:paddingBottom="110dp">

        <!-- GUIDELINES (3 zones horizontales) -->
        <androidx.constraintlayout.widget.Guideline android:id="@+id/gl_top_zone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" app:layout_constraintGuide_percent="0.33" />
        <androidx.constraintlayout.widget.Guideline android:id="@+id/gl_middle_zone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" app:layout_constraintGuide_percent="0.66" />

        <!-- 1. ZONE TOP : CONTEXTE + ACTIONS -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/container_parent"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginStart="8dp"
            android:layout_marginTop="4dp"
            app:cardCornerRadius="12dp"
            app:strokeWidth="2dp"
            app:strokeColor="@color/material_dynamic_neutral90"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="match_parent" android:layout_height="match_parent" android:padding="4dp">
                <ImageView android:id="@+id/iv_parent" android:layout_width="match_parent" android:layout_height="0dp" android:scaleType="centerInside" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toTopOf="@id/tv_parent_label" />
                <TextView android:id="@+id/tv_parent_label" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:textSize="8sp" android:textStyle="bold" android:maxLines="1" app:layout_constraintBottom_toBottomOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Fil d'Ariane Horizontal -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/container_breadcrumbs"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_marginTop="4dp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="8dp"
            app:layout_constraintStart_toEndOf="@id/container_parent"
            app:layout_constraintEnd_toStartOf="@id/container_actions"
            app:layout_constraintTop_toTopOf="parent">
            <androidx.recyclerview.widget.RecyclerView android:id="@+id/rv_breadcrumbs" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="horizontal" android:clipToPadding="false" tools:listitem="@layout/item_breadcrumb" />
            <View android:id="@+id/breadcrumb_scroll_top" android:layout_width="30dp" android:layout_height="match_parent" android:background="@drawable/scroll_gradient_left" android:visibility="invisible" app:layout_constraintStart_toStartOf="parent" />
            <View android:id="@+id/breadcrumb_scroll_bottom" android:layout_width="30dp" android:layout_height="match_parent" android:background="@drawable/scroll_gradient_right" android:visibility="invisible" app:layout_constraintEnd_toEndOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- BLOC ACTIONS (En haut à droite - MARGE DE SÉCURITÉ 100dp) -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/container_actions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="60dp"
            android:elevation="10dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <com.google.android.material.card.MaterialCardView android:id="@+id/card_search" android:layout_width="40dp" android:layout_height="40dp" app:cardCornerRadius="10dp" app:cardBackgroundColor="#EDE7F6" app:cardElevation="2dp"><ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:padding="10dp" android:src="@android:drawable/ic_menu_search" app:tint="#5E35B1" /></com.google.android.material.card.MaterialCardView>
            <com.google.android.material.card.MaterialCardView android:id="@+id/card_speak" android:layout_width="40dp" android:layout_height="40dp" app:cardCornerRadius="10dp" app:cardBackgroundColor="#E8F5E9" app:cardElevation="2dp"><ImageView android:id="@+id/iv_speak_icon" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="10dp" android:src="@android:drawable/ic_btn_speak_now" app:tint="#2E7D32" /></com.google.android.material.card.MaterialCardView>
            <com.google.android.material.card.MaterialCardView android:id="@+id/card_rotate" android:layout_width="40dp" android:layout_height="40dp" app:cardCornerRadius="10dp" app:cardBackgroundColor="#FFF3E0" app:cardElevation="2dp"><ImageView android:id="@+id/iv_menu_rotate" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="10dp" android:src="@android:drawable/ic_menu_rotate" app:tint="#E65100" /></com.google.android.material.card.MaterialCardView>
            <com.google.android.material.card.MaterialCardView android:id="@+id/card_back_to_trees" android:layout_width="40dp" android:layout_height="40dp" app:cardCornerRadius="10dp" app:cardBackgroundColor="#EDE7F6" app:cardElevation="2dp"><ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:padding="10dp" android:src="@android:drawable/ic_dialog_dialer" app:tint="#5E35B1" /></com.google.android.material.card.MaterialCardView>
            <com.google.android.material.card.MaterialCardView android:id="@+id/card_eye" android:layout_width="40dp" android:layout_height="40dp" app:cardCornerRadius="10dp" app:cardBackgroundColor="#EDE7F6" app:cardElevation="2dp"><ImageView android:id="@+id/iv_eye" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="10dp" android:src="@drawable/ic_tree_structure" app:tint="#5E35B1" /></com.google.android.material.card.MaterialCardView>
            <androidx.constraintlayout.helper.widget.Flow android:id="@+id/flow_actions_land" android:layout_width="wrap_content" android:layout_height="wrap_content" app:flow_wrapMode="aligned" app:flow_maxElementsWrap="3" app:flow_horizontalGap="8dp" app:flow_verticalGap="8dp" app:constraint_referenced_ids="card_search,card_speak,card_rotate,card_back_to_trees,card_eye" app:layout_constraintTop_toTopOf="parent" app:layout_constraintEnd_toEndOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>


        <!-- 2. ZONE MIDDLE : LES FRÈRES (Horizontal) -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_siblings"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:clipToPadding="false"
            android:paddingStart="16dp"
            android:paddingEnd="120dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/gl_top_zone"
            app:layout_constraintBottom_toTopOf="@id/gl_middle_zone"
            tools:listitem="@layout/item_sibling_node" />

        <!-- Indicateurs Frères -->
        <View android:id="@+id/siblings_gradient_left" android:layout_width="40dp" android:layout_height="0dp" android:background="@drawable/scroll_gradient_left" android:visibility="invisible" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="@id/rv_siblings" app:layout_constraintBottom_toBottomOf="@id/rv_siblings" />
        <View android:id="@+id/siblings_gradient_right" android:layout_width="40dp" android:layout_height="0dp" android:background="@drawable/scroll_gradient_right" android:visibility="invisible" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toTopOf="@id/rv_siblings" app:layout_constraintBottom_toBottomOf="@id/rv_siblings" />


        <!-- 3. ZONE BOTTOM : LES ENFANTS (Horizontal) + AJOUTER -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_children_preview"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:clipToPadding="false"
            android:paddingStart="16dp"
            android:paddingEnd="160dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/gl_middle_zone"
            app:layout_constraintBottom_toBottomOf="parent"
            tools:listitem="@layout/item_sibling_node" />

        <!-- Bloc Ajouter (Bas droite - MARGE DE SÉCURITÉ 100dp) -->
        <LinearLayout
            android:id="@+id/layout_action"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginEnd="60dp"
            android:layout_marginBottom="4dp"
            android:elevation="10dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">
            <ImageView android:id="@+id/iv_selected_large" android:layout_width="50dp" android:layout_height="50dp" android:background="@drawable/rounded_bottom_sheet" android:backgroundTint="#F0F0F0" android:padding="4dp" android:scaleType="centerInside" />
            <com.google.android.material.button.MaterialButton android:id="@+id/btn_add_to_phrase" android:layout_width="wrap_content" android:layout_height="32dp" android:layout_marginTop="2dp" android:text="Ajouter" android:textSize="9sp" android:textAllCaps="false" app:cornerRadius="16dp" />
        </LinearLayout>

        <!-- FLÈCHES HIÉRARCHIQUES -->
        <ImageView android:id="@+id/iv_arrow_to_siblings" android:layout_width="20dp" android:layout_height="20dp" android:src="@android:drawable/arrow_down_float" app:tint="@color/primary_color" android:elevation="15dp" app:layout_constraintTop_toBottomOf="@id/container_parent" app:layout_constraintBottom_toTopOf="@id/rv_siblings" app:layout_constraintStart_toStartOf="@id/container_parent" app:layout_constraintEnd_toEndOf="@id/container_parent" />
        <ImageView android:id="@+id/iv_arrow_to_children" android:layout_width="20dp" android:layout_height="20dp" android:src="@android:drawable/arrow_down_float" android:visibility="invisible" app:tint="@color/primary_color" android:elevation="15dp" app:layout_constraintTop_toBottomOf="@id/gl_middle_zone" app:layout_constraintBottom_toTopOf="@id/gl_middle_zone" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/panel_phrase"
        android:layout_width="match_parent"
        android:layout_height="110dp"
        android:layout_gravity="bottom"
        android:background="@drawable/rounded_bottom_sheet"
        android:elevation="20dp">
        
        <!-- RecyclerView en premier -->
        <androidx.recyclerview.widget.RecyclerView 
            android:id="@+id/rv_phrase" 
            android:layout_width="0dp" 
            android:layout_height="match_parent" 
            android:layout_marginTop="4dp" 
            android:layout_marginBottom="4dp" 
            android:clipToPadding="false" 
            android:paddingHorizontal="24dp" 
            android:orientation="horizontal" 
            app:layout_constraintTop_toTopOf="parent" 
            app:layout_constraintBottom_toBottomOf="parent" 
            app:layout_constraintStart_toStartOf="parent" 
            app:layout_constraintEnd_toEndOf="parent" 
            tools:listitem="@layout/item_phrase_picto" />

        <!-- Boutons en dernier avec haute elevation -->
        <ImageButton 
            android:id="@+id/btn_fullscreen_phrase" 
            android:layout_width="40dp" 
            android:layout_height="40dp" 
            android:layout_margin="4dp" 
            android:background="?attr/selectableItemBackgroundBorderless" 
            android:src="@android:drawable/ic_menu_zoom" 
            android:elevation="25dp" 
            app:layout_constraintTop_toTopOf="parent" 
            app:layout_constraintEnd_toEndOf="parent" />

        <ImageButton 
            android:id="@+id/btn_clear_phrase" 
            android:layout_width="40dp" 
            android:layout_height="40dp" 
            android:layout_margin="4dp" 
            android:background="?attr/selectableItemBackgroundBorderless" 
            android:src="@android:drawable/ic_menu_delete" 
            android:elevation="25dp" 
            app:layout_constraintTop_toBottomOf="@id/btn_fullscreen_phrase" 
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <View android:id="@+id/fab_speak" android:layout_width="1dp" android:layout_height="1dp" android:visibility="gone" />
    <View android:id="@+id/iv_siblings_arrow_left" android:layout_width="1dp" android:layout_height="1dp" android:visibility="gone" />
    <View android:id="@+id/iv_siblings_arrow_right" android:layout_width="1dp" android:layout_height="1dp" android:visibility="gone" />
    <View android:id="@+id/iv_children_arrow_left" android:layout_width="1dp" android:layout_height="1dp" android:visibility="gone" />
    <View android:id="@+id/iv_children_arrow_right" android:layout_width="1dp" android:layout_height="1dp" android:visibility="gone" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
