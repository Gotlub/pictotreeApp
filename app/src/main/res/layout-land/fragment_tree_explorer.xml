<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="120dp"
        android:clipChildren="false">

        <androidx.constraintlayout.widget.Guideline android:id="@+id/gl_v1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" app:layout_constraintGuide_percent="0.35" />
        <androidx.constraintlayout.widget.Guideline android:id="@+id/gl_v2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" app:layout_constraintGuide_percent="0.70" />

        <!-- 1. NAVIGATION LAYERS (Columns) -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_siblings"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:paddingVertical="16dp"
            android:clipToPadding="false"
            app:layout_constraintStart_toEndOf="@id/gl_v1"
            app:layout_constraintEnd_toStartOf="@id/gl_v2"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/bottom_nav_zone"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            app:layout_constraintStart_toEndOf="@id/gl_v2"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">
            <androidx.recyclerview.widget.RecyclerView android:id="@+id/rv_children_preview" android:layout_width="match_parent" android:layout_height="match_parent" android:paddingVertical="16dp" android:clipToPadding="false" />
            <View android:id="@+id/children_gradient_left" android:layout_width="30dp" android:layout_height="match_parent" android:background="@drawable/scroll_gradient_left" android:visibility="invisible" app:layout_constraintStart_toStartOf="parent" />
            <View android:id="@+id/children_gradient_right" android:layout_width="30dp" android:layout_height="match_parent" android:background="@drawable/scroll_gradient_right" android:visibility="invisible" app:layout_constraintEnd_toEndOf="parent" />
            <ImageView android:id="@+id/iv_children_arrow_left" android:layout_width="20dp" android:layout_height="20dp" android:src="@android:drawable/ic_media_previous" android:visibility="invisible" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent" />
            <ImageView android:id="@+id/iv_children_arrow_right" android:layout_width="20dp" android:layout_height="20dp" android:src="@android:drawable/ic_media_next" android:visibility="invisible" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- 2. FIXED PANELS (Columns) -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/left_top_fixed_panel"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:elevation="10dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/gl_v1"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">
            
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/container_parent"
                android:layout_width="120dp"
                android:layout_height="140dp"
                android:layout_marginTop="8dp"
                app:cardCornerRadius="16dp"
                app:strokeWidth="3dp"
                app:strokeColor="@color/material_dynamic_neutral90"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">
                <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="match_parent" android:layout_height="match_parent" android:padding="4dp">
                    <ImageView android:id="@+id/iv_parent" android:layout_width="match_parent" android:layout_height="0dp" android:scaleType="centerInside" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toTopOf="@id/tv_parent_label" />
                    <TextView android:id="@+id/tv_parent_label" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:textSize="12sp" android:textStyle="bold" app:layout_constraintBottom_toBottomOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout android:id="@+id/layout_action" android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent" android:layout_marginBottom="16dp">
                <ImageView android:id="@+id/iv_selected_large" android:layout_width="60dp" android:layout_height="60dp" android:background="@drawable/rounded_bottom_sheet" android:backgroundTint="#F0F0F0" android:padding="4dp" android:scaleType="centerInside" />
                <com.google.android.material.button.MaterialButton android:id="@+id/btn_add_to_phrase" android:layout_width="wrap_content" android:layout_height="36dp" android:layout_marginTop="4dp" android:text="Add" android:textSize="10sp" android:textAllCaps="false" app:cornerRadius="18dp" />
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- BLOC ACTIONS DOUBLE COLONNE (DROITE) -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/container_actions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            android:elevation="12dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.card.MaterialCardView android:id="@+id/card_search" android:layout_width="40dp" android:layout_height="40dp" app:cardCornerRadius="10dp" app:cardBackgroundColor="#EDE7F6" />
            <com.google.android.material.card.MaterialCardView android:id="@+id/card_speak" android:layout_width="40dp" android:layout_height="40dp" app:cardCornerRadius="10dp" app:cardBackgroundColor="#E8F5E9" />
            <com.google.android.material.card.MaterialCardView android:id="@+id/card_rotate" android:layout_width="40dp" android:layout_height="40dp" app:cardCornerRadius="10dp" app:cardBackgroundColor="#FFF3E0" />
            <com.google.android.material.card.MaterialCardView android:id="@+id/card_back_to_trees" android:layout_width="40dp" android:layout_height="40dp" app:cardCornerRadius="10dp" app:cardBackgroundColor="#EDE7F6" />
            <com.google.android.material.card.MaterialCardView android:id="@+id/card_eye" android:layout_width="40dp" android:layout_height="40dp" app:cardCornerRadius="10dp" app:cardBackgroundColor="#EDE7F6" />

            <!-- COLONNE DROITE (Navigation) -->
            <androidx.constraintlayout.helper.widget.Flow
                android:id="@+id/flow_actions_right"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:flow_verticalGap="8dp"
                app:constraint_referenced_ids="card_back_to_trees,card_eye"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- COLONNE GAUCHE (Outils) -->
            <androidx.constraintlayout.helper.widget.Flow
                android:id="@+id/flow_actions_left"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:flow_verticalGap="8dp"
                app:constraint_referenced_ids="card_search,card_speak,card_rotate"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toStartOf="@id/flow_actions_right"
                android:layout_marginEnd="8dp" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- 3. TOP LAYERS -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/container_breadcrumbs"
            android:layout_width="60dp"
            android:layout_height="0dp"
            android:elevation="14dp"
            app:layout_constraintStart_toEndOf="@id/left_top_fixed_panel"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">
            <androidx.recyclerview.widget.RecyclerView android:id="@+id/rv_breadcrumbs" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" />
            <View android:id="@+id/breadcrumb_scroll_top" android:layout_width="match_parent" android:layout_height="20dp" android:background="@drawable/scroll_gradient_top" android:visibility="invisible" app:layout_constraintTop_toTopOf="parent" />
            <View android:id="@+id/breadcrumb_scroll_bottom" android:layout_width="match_parent" android:layout_height="20dp" android:background="@drawable/scroll_gradient_bottom" android:visibility="invisible" app:layout_constraintBottom_toBottomOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <ImageView android:id="@+id/iv_arrow_to_siblings" android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_media_next" app:tint="#CCCCCC" android:elevation="15dp" app:layout_constraintTop_toTopOf="@id/container_parent" app:layout_constraintBottom_toBottomOf="@id/container_parent" app:layout_constraintStart_toEndOf="@id/container_parent" />
        <ImageView android:id="@+id/iv_arrow_to_children" android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_media_next" android:visibility="invisible" app:tint="#CCCCCC" android:elevation="15dp" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintEnd_toEndOf="@id/rv_siblings" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/panel_phrase"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_gravity="bottom"
        android:background="@drawable/rounded_bottom_sheet"
        android:elevation="20dp">
        <ImageButton android:id="@+id/btn_fullscreen_phrase" android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="4dp" android:src="@android:drawable/ic_menu_zoom" app:layout_constraintTop_toTopOf="parent" app:layout_constraintEnd_toEndOf="parent" />
        <androidx.recyclerview.widget.RecyclerView android:id="@+id/rv_phrase" android:layout_width="0dp" android:layout_height="0dp" android:layout_marginTop="4dp" android:layout_marginBottom="4dp" android:paddingHorizontal="16dp" android:orientation="horizontal" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <View android:id="@+id/fab_speak" android:layout_width="1dp" android:layout_height="1dp" android:visibility="gone" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
